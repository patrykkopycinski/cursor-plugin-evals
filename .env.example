# Plugin path
PLUGIN_DIR=/path/to/your-cursor-plugin

# Elasticsearch credentials (for test cluster)
ES_URL=http://localhost:9220
ES_API_KEY=

# Kibana
KIBANA_URL=http://localhost:5620

# LLM API keys (at least one required for LLM eval layer)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LLM judge configuration (for LLM evaluators)
JUDGE_MODEL=gpt-4o
LITELLM_URL=

# Optional: LiteLLM proxy for model routing
LITELLM_PROXY_URL=

# Optional: LangSmith tracing
LANGCHAIN_API_KEY=
