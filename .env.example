# Plugin path
PLUGIN_DIR=/path/to/your-cursor-plugin

# Elasticsearch credentials (for test cluster)
ES_URL=http://localhost:9220
ES_API_KEY=

# Kibana
KIBANA_URL=http://localhost:5620

# LLM API keys (at least one required for LLM eval layer)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Azure OpenAI (alternative to OPENAI_API_KEY)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# LLM judge configuration (for LLM evaluators)
JUDGE_MODEL=gpt-4o
AZURE_JUDGE_DEPLOYMENT=
LITELLM_URL=

# Optional: LiteLLM proxy for model routing
LITELLM_PROXY_URL=

# Optional: LangSmith tracing
LANGCHAIN_API_KEY=

# LLM response cache
CPE_CACHE_ENABLED=true
CPE_CACHE_TTL=7d
CPE_CACHE_DIR=.cursor-plugin-evals/cache

# Eval results storage (for history command)
EVALUATIONS_ES_URL=http://localhost:9200

# Notifications
SLACK_WEBHOOK_URL=
GITHUB_TOKEN=

# Elastic Cloud (for cloud API testing)
ELASTIC_CLOUD_API_KEY=
