{
  "name": "cursor-plugin-evals",
  "version": "0.0.1",
  "description": "End-to-end testing framework for Cursor plugins that expose MCP servers",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cursor-plugin-evals": "dist/cli/main.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "doctor": "node dist/cli/main.js doctor",
    "generate": "node dist/cli/main.js generate"
  },
  "keywords": [
    "cursor",
    "plugin",
    "mcp",
    "testing",
    "evaluation",
    "model-context-protocol"
  ],
  "author": "Patryk Kopycinski",
  "license": "Elastic-2.0",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@inquirer/prompts": "^8.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "hono": "^4.12.7",
    "object-hash": "^3.0.0",
    "open": "^11.0.0",
    "p-limit": "^7.3.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/object-hash": "^3.0.6",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  }
}
